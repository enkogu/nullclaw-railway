# IMPORTANT (Railway): use raw values (no wrapping quotes)
# Good: NULLCLAW_PROVIDER=anthropic
# Bad:  NULLCLAW_PROVIDER="anthropic"

# Core provider/model
NULLCLAW_PROVIDER=openrouter
# NULLCLAW_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_API_KEY=sk-or-...
# NULLCLAW_API_KEY=...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_OAUTH_TOKEN=sk-ant-oat01-...

# OpenAI Codex subscription auth (if NULLCLAW_PROVIDER=openai-codex)
# OPENAI_CODEX_ACCESS_TOKEN=...
# OPENAI_CODEX_REFRESH_TOKEN=...
# OPENAI_CODEX_EXPIRES_AT=0

# Gateway
NULLCLAW_GATEWAY_HOST=0.0.0.0
NULLCLAW_ALLOW_PUBLIC_BIND=true
NULLCLAW_REQUIRE_PAIRING=false
NULLCLAW_REWRITE_CONFIG=false
PORT=3000

# Telegram
# TELEGRAM_BOT_TOKEN=123456789:AA...
# TELEGRAM_ACCOUNT_ID=main
# TELEGRAM_ALLOW_FROM=*
# TELEGRAM_GROUP_ALLOW_FROM=
# TELEGRAM_GROUP_POLICY=allowlist

# Audio transcription
NULLCLAW_AUDIO_ENABLED=true
# NULLCLAW_AUDIO_PROVIDER=groq
# NULLCLAW_AUDIO_MODEL=whisper-large-v3
# NULLCLAW_AUDIO_API_KEY=
# GROQ_API_KEY=
# NULLCLAW_AUDIO_LANGUAGE=en
# NULLCLAW_AUDIO_BASE_URL=

# Memory
NULLCLAW_MEMORY_BACKEND=sqlite
NULLCLAW_MEMORY_AUTO_SAVE=true
NULLCLAW_MEMORY_SEARCH_ENABLED=true
NULLCLAW_MEMORY_SEARCH_PROVIDER=none
# NULLCLAW_MEMORY_SEARCH_MODEL=text-embedding-3-small
# NULLCLAW_MEMORY_API_KEY=
# NULLCLAW_MEMORY_PROFILE=
# NULLCLAW_MEMORY_CITATIONS=auto
# NULLCLAW_MEMORY_HYBRID_ENABLED=false

# Web search / HTTP tool
NULLCLAW_HTTP_ENABLED=true
NULLCLAW_WEB_SEARCH_PROVIDER=auto
# NULLCLAW_WEB_SEARCH_BASE_URL=https://searx.example.com
# NULLCLAW_WEB_SEARCH_FALLBACK_PROVIDERS=jina,duckduckgo
# NULLCLAW_HTTP_ALLOWED_DOMAINS=example.com,api.example.com
# NULLCLAW_HTTP_TIMEOUT_SECS=30
# NULLCLAW_HTTP_MAX_RESPONSE_SIZE=1000000
# BRAVE_API_KEY=
# FIRECRAWL_API_KEY=
# TAVILY_API_KEY=
# PERPLEXITY_API_KEY=
# EXA_API_KEY=
# JINA_API_KEY=

# Browser tool + browser_open allowlist
# NULLCLAW_BROWSER_ENABLED=true
# NULLCLAW_BROWSER_BACKEND=agent_browser
# NULLCLAW_BROWSER_NATIVE_HEADLESS=true
# NULLCLAW_BROWSER_NATIVE_WEBDRIVER_URL=http://127.0.0.1:9515
# NULLCLAW_BROWSER_NATIVE_CHROME_PATH=
# NULLCLAW_BROWSER_SESSION_NAME=railway
# NULLCLAW_BROWSER_ALLOWED_DOMAINS=example.com,openai.com

# PinchTab + noVNC (shared human/agent browser sessions with profile persistence)
PINCHTAB_ENABLED=true
PINCHTAB_BIND=0.0.0.0
PINCHTAB_PORT=9867
# PINCHTAB_TOKEN=replace-with-strong-token
PINCHTAB_HEADLESS_DEFAULT=true
PINCHTAB_STATE_DIR=/data/.pinchtab
# PINCHTAB_PROFILE=default
# PINCHTAB_CHROME_BINARY=/usr/bin/chromium-browser
# PINCHTAB_CHROME_FLAGS=--no-sandbox --disable-gpu --disable-dev-shm-usage
# PINCHTAB_STEALTH=light
# PINCHTAB_BLOCK_ADS=false
# PINCHTAB_BLOCK_IMAGES=false
# PINCHTAB_BLOCK_MEDIA=false

# noVNC bridge for headed-mode login
PINCHTAB_NOVNC_ENABLED=true
PINCHTAB_DISPLAY=:99
PINCHTAB_SCREEN=1280x720x24
PINCHTAB_VNC_PORT=5900
PINCHTAB_NOVNC_PORT=6080
# Single-port platforms (Railway): expose noVNC at https://<host>/novnc/vnc.html
PINCHTAB_NOVNC_PUBLIC_PATH=/novnc
# NULLCLAW_GATEWAY_INTERNAL_PORT=3001
# PINCHTAB_VNC_PASSWORD=replace-with-strong-password
# PINCHTAB_VNC_VIEW_ONLY=false
# PINCHTAB_NOVNC_WEB_DIR=/usr/share/novnc
# PINCHTAB_STARTUP_TIMEOUT_SECS=30

# Legacy Playwright MCP (not installed in this image by default)
# NULLCLAW_MCP_PLAYWRIGHT_ENABLED=false
# NULLCLAW_MCP_PLAYWRIGHT_COMMAND=npx
# NULLCLAW_MCP_PLAYWRIGHT_PACKAGE=@playwright/mcp
# NULLCLAW_MCP_PLAYWRIGHT_HEADLESS=true
# NULLCLAW_MCP_PLAYWRIGHT_ISOLATED=false
# NULLCLAW_MCP_PLAYWRIGHT_BROWSER=chrome
# NULLCLAW_MCP_PLAYWRIGHT_EXECUTABLE_PATH=/usr/bin/chromium-browser
# NULLCLAW_MCP_PLAYWRIGHT_USER_DATA_DIR=/data/.nullclaw/playwright-profile
# NULLCLAW_MCP_PLAYWRIGHT_OUTPUT_DIR=/data/.nullclaw/playwright-output
# NULLCLAW_MCP_PLAYWRIGHT_SAVE_SESSION=true
# NULLCLAW_MCP_PLAYWRIGHT_SHARED_BROWSER_CONTEXT=true
# NULLCLAW_MCP_PLAYWRIGHT_NO_SANDBOX=true
# NULLCLAW_MCP_PLAYWRIGHT_CDP_ENDPOINT=wss://<your-cdp-endpoint>
# NULLCLAW_MCP_PLAYWRIGHT_CDP_HEADER=Authorization: Bearer <token>
# NULLCLAW_MCP_PLAYWRIGHT_ALLOWED_HOSTS=*
# NULLCLAW_MCP_PLAYWRIGHT_ALLOWED_ORIGINS=*
# NULLCLAW_MCP_PLAYWRIGHT_IGNORE_HTTPS_ERRORS=false

# Shell/autonomy
NULLCLAW_AUTONOMY_LEVEL=supervised
NULLCLAW_WORKSPACE_ONLY=true
NULLCLAW_MAX_ACTIONS_PER_HOUR=20
# NULLCLAW_ALLOWED_COMMANDS=*
# NULLCLAW_ALLOWED_PATHS=*
NULLCLAW_REQUIRE_APPROVAL_FOR_MEDIUM_RISK=true
NULLCLAW_BLOCK_HIGH_RISK_COMMANDS=true
# NULLCLAW_SHELL_TIMEOUT_SECS=60
# NULLCLAW_SHELL_MAX_OUTPUT_BYTES=1048576
# NULLCLAW_MAX_FILE_SIZE_BYTES=10485760
# NULLCLAW_WEB_FETCH_MAX_CHARS=100000

# Provider reliability/fallbacks
# NULLCLAW_RELIABILITY_PROVIDER_RETRIES=2
# NULLCLAW_RELIABILITY_PROVIDER_BACKOFF_MS=500
# NULLCLAW_RELIABILITY_FALLBACK_PROVIDERS=openrouter,groq
# NULLCLAW_RELIABILITY_API_KEYS=
# NULLCLAW_RELIABILITY_MODEL_FALLBACK_SOURCE=claude-sonnet-4-6
# NULLCLAW_RELIABILITY_MODEL_FALLBACKS=groq/llama-3.3-70b-versatile

# Web channel / relay
# NULLCLAW_WEB_ENABLED=true
# NULLCLAW_WEB_ACCOUNT_ID=main
# NULLCLAW_WEB_TRANSPORT=local
# NULLCLAW_WEB_LISTEN=127.0.0.1
# NULLCLAW_WEB_PORT=32123
# NULLCLAW_WEB_PATH=/ws
# NULLCLAW_WEB_MESSAGE_AUTH_MODE=pairing
# NULLCLAW_WEB_AUTH_TOKEN=replace-with-random-token
# NULLCLAW_WEB_ALLOWED_ORIGINS=http://localhost:5173,chrome-extension://your-extension-id
# Relay placeholders are auto-disabled by entrypoint; set real values to enable.
# NULLCLAW_WEB_RELAY_URL=wss://relay.nullclaw.io/ws/agent
# NULLCLAW_WEB_RELAY_AGENT_ID=default
# NULLCLAW_WEB_RELAY_TOKEN=
# NULLCLAW_WEB_RELAY_TOKEN_TTL_SECS=2592000
# NULLCLAW_WEB_RELAY_PAIRING_CODE_TTL_SECS=300
# NULLCLAW_WEB_RELAY_UI_TOKEN_TTL_SECS=86400
# NULLCLAW_WEB_RELAY_E2E_REQUIRED=false

# Helper script defaults (used by scripts/pinchtab-client.sh)
# PINCHTAB_BASE_URL=http://127.0.0.1:9867
# PINCHTAB_SESSION_MAP_DIR=/data/.nullclaw/pinchtab-sessions
