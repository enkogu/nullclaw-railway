# Required: either generic key or provider-specific key
# NULLCLAW_API_KEY=sk-...

# Optional
NULLCLAW_PROVIDER=openrouter
# NULLCLAW_MODEL=anthropic/claude-sonnet-4.6
# If omitted, provider-specific defaults are used.
OPENROUTER_API_KEY=sk-or-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_OAUTH_TOKEN=sk-ant-oat01-...   # Claude subscription/setup token
# OPENAI_CODEX_ACCESS_TOKEN=...             # ChatGPT Plus/Pro subscription token
# OPENAI_CODEX_REFRESH_TOKEN=...
# OPENAI_CODEX_EXPIRES_AT=0
NULLCLAW_GATEWAY_HOST=0.0.0.0
NULLCLAW_ALLOW_PUBLIC_BIND=true
NULLCLAW_REQUIRE_PAIRING=false
NULLCLAW_REWRITE_CONFIG=false
PORT=3000

# Optional Telegram channel wiring (for polling mode)
# TELEGRAM_BOT_TOKEN=123456789:AA...
# TELEGRAM_ACCOUNT_ID=main
# TELEGRAM_ALLOW_FROM=*                  # or comma-separated usernames/user IDs
# TELEGRAM_GROUP_ALLOW_FROM=             # optional comma-separated list
# TELEGRAM_GROUP_POLICY=allowlist        # allowlist | open | disabled
