# Required: either generic key or provider-specific key
# NULLCLAW_API_KEY=sk-...

# Optional
NULLCLAW_PROVIDER=openrouter
# NULLCLAW_MODEL=anthropic/claude-sonnet-4.6
# If omitted, provider-specific defaults are used.
OPENROUTER_API_KEY=sk-or-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
NULLCLAW_GATEWAY_HOST=0.0.0.0
NULLCLAW_ALLOW_PUBLIC_BIND=true
NULLCLAW_REQUIRE_PAIRING=false
NULLCLAW_REWRITE_CONFIG=false
PORT=3000
