{
  "workspace": "/data/.nullclaw/workspace",
  "default_temperature": 0.7,
  "models": {
    "providers": {
      "anthropic": { "api_key": "sk-ant-oat01-..." }
    }
  },
  "agents": {
    "defaults": {
      "model": { "primary": "anthropic/claude-sonnet-4-6" }
    }
  },
  "tools": {
    "shell_timeout_secs": 120,
    "shell_max_output_bytes": 2097152,
    "max_file_size_bytes": 20971520,
    "web_fetch_max_chars": 200000,
    "media": {
      "audio": {
        "enabled": true,
        "models": [{ "provider": "groq", "model": "whisper-large-v3" }]
      }
    }
  },
  "memory": {
    "backend": "sqlite",
    "auto_save": true,
    "citations": "auto",
    "search": {
      "enabled": false,
      "provider": "none",
      "model": "text-embedding-3-small",
      "fallback_provider": "none",
      "query": {
        "hybrid": { "enabled": false }
      }
    }
  },
  "http_request": {
    "enabled": true,
    "max_response_size": 1000000,
    "timeout_secs": 30,
    "allowed_domains": [],
    "search_provider": "duckduckgo",
    "search_fallback_providers": []
  },
  "browser": {
    "enabled": true,
    "backend": "agent_browser",
    "native_headless": true,
    "native_webdriver_url": "http://127.0.0.1:9515",
    "allowed_domains": ["example.com", "openai.com"]
  },
  "autonomy": {
    "level": "full",
    "workspace_only": false,
    "max_actions_per_hour": 20,
    "require_approval_for_medium_risk": false,
    "block_high_risk_commands": false,
    "allowed_commands": ["*"],
    "allowed_paths": ["*"]
  },
  "channels": {
    "telegram": {
      "accounts": {
        "main": {
          "bot_token": "123456:ABC...",
          "allow_from": ["*"],
          "group_allow_from": [],
          "group_policy": "allowlist"
        }
      }
    },
    "web": {
      "accounts": {
        "main": {
          "transport": "relay",
          "listen": "127.0.0.1",
          "port": 32123,
          "path": "/ws",
          "max_connections": 10,
          "auth_token": null,
          "message_auth_mode": "pairing",
          "allowed_origins": ["https://your-ui-domain"],
          "relay_url": "wss://relay.nullclaw.io/ws/agent",
          "relay_agent_id": "default",
          "relay_token": "replace-with-16-128-char-token",
          "relay_token_ttl_secs": 2592000,
          "relay_pairing_code_ttl_secs": 300,
          "relay_ui_token_ttl_secs": 86400,
          "relay_e2e_required": false
        }
      }
    }
  },
  "gateway": {
    "port": 3000,
    "host": "0.0.0.0",
    "allow_public_bind": true,
    "require_pairing": false
  }
}
