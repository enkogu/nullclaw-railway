+test "Agent turn prunes internal tool_result scaffolding before next turn" {
+    const EchoTool = struct {
+        const Self = @This();
+        pub const tool_name = "echo_tool";
+        pub const tool_description = "Returns a short success marker";
+        pub const tool_params = "{\"type\":\"object\",\"properties\":{},\"additionalProperties\":false}";
+        pub const vtable = tools_mod.ToolVTable(Self);
+
+        fn tool(self: *Self) Tool {
+            return .{ .ptr = @ptrCast(self), .vtable = &vtable };
+        }
+
+        pub fn execute(_: *Self, allocator: std.mem.Allocator, _: tools_mod.JsonObjectMap) !tools_mod.ToolResult {
+            return .{ .success = true, .output = try allocator.dupe(u8, "ok") };
+        }
+    };
+
+    const HistoryProbeProvider = struct {
+        const Self = @This();
+        call_count: usize = 0,
+
+        fn chatWithSystem(_: *anyopaque, allocator: std.mem.Allocator, _: ?[]const u8, _: []const u8, _: []const u8, _: f64) anyerror![]const u8 {
+            return allocator.dupe(u8, "");
+        }
+
+        fn hasToolResultLeak(messages: []const providers.ChatMessage) bool {
+            for (messages) |msg| {
+                if (msg.role != .user) continue;
+                const trimmed = std.mem.trim(u8, msg.content, " \t\r\n");
+                if (std.mem.startsWith(u8, trimmed, "<tool_result")) return true;
+            }
+            return false;
+        }
+
+        fn chat(ptr: *anyopaque, allocator: std.mem.Allocator, request: providers.ChatRequest, _: []const u8, _: f64) anyerror!providers.ChatResponse {
+            const self: *Self = @ptrCast(@alignCast(ptr));
+            self.call_count += 1;
+
+            if (self.call_count == 1) {
+                const tool_calls = try allocator.alloc(providers.ToolCall, 1);
+                tool_calls[0] = .{
+                    .id = try allocator.dupe(u8, "call-1"),
+                    .name = try allocator.dupe(u8, "echo_tool"),
+                    .arguments = try allocator.dupe(u8, "{}"),
+                };
+                return .{
+                    .content = try allocator.dupe(u8, "running"),
+                    .tool_calls = tool_calls,
+                    .usage = .{},
+                    .model = try allocator.dupe(u8, "test-model"),
+                };
+            }
+
+            if (self.call_count == 2) {
+                return .{
+                    .content = try allocator.dupe(u8, "first turn done"),
+                    .tool_calls = &.{},
+                    .usage = .{},
+                    .model = try allocator.dupe(u8, "test-model"),
+                };
+            }
+
+            const has_leak = hasToolResultLeak(request.messages);
+            return .{
+                .content = try allocator.dupe(u8, if (has_leak) "LEAKED_TOOL_RESULT" else "CLEAN_HISTORY"),
+                .tool_calls = &.{},
+                .usage = .{},
+                .model = try allocator.dupe(u8, "test-model"),
+            };
+        }
+
+        fn supportsNativeTools(_: *anyopaque) bool {
+            return true;
+        }
+
+        fn getName(_: *anyopaque) []const u8 {
+            return "history-probe";
+        }
+
+        fn deinitFn(_: *anyopaque) void {}
+    };
+
+    const allocator = std.testing.allocator;
+
+    var provider_state = HistoryProbeProvider{};
+    const provider_vtable = Provider.VTable{
+        .chatWithSystem = HistoryProbeProvider.chatWithSystem,
+        .chat = HistoryProbeProvider.chat,
+        .supportsNativeTools = HistoryProbeProvider.supportsNativeTools,
+        .getName = HistoryProbeProvider.getName,
+        .deinit = HistoryProbeProvider.deinitFn,
+    };
+    const provider = Provider{
+        .ptr = @ptrCast(&provider_state),
+        .vtable = &provider_vtable,
+    };
+
+    var tool_impl = EchoTool{};
+    const tool_list = [_]Tool{tool_impl.tool()};
+
+    var specs = try allocator.alloc(ToolSpec, tool_list.len);
+    for (tool_list, 0..) |t, i| {
+        specs[i] = .{
+            .name = t.name(),
+            .description = t.description(),
+            .parameters_json = t.parametersJson(),
+        };
+    }
+
+    var noop = observability.NoopObserver{};
+    var agent = Agent{
+        .allocator = allocator,
+        .provider = provider,
+        .tools = &tool_list,
+        .tool_specs = specs,
+        .mem = null,
+        .observer = noop.observer(),
+        .model_name = "test-model",
+        .temperature = 0.7,
+        .workspace_dir = "/tmp",
+        .max_tool_iterations = 4,
+        .max_history_messages = 50,
+        .auto_save = false,
+        .history = .empty,
+        .total_tokens = 0,
+        .has_system_prompt = false,
+    };
+    defer agent.deinit();
+
+    const first = try agent.turn("run tool");
+    defer allocator.free(first);
+    try std.testing.expectEqualStrings("first turn done", first);
+
+    const second = try agent.turn("second turn");
+    defer allocator.free(second);
+    try std.testing.expectEqualStrings("CLEAN_HISTORY", second);
+
+    try std.testing.expectEqual(@as(usize, 3), provider_state.call_count);
+}
