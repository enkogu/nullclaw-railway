+    fn pruneInternalToolArtifacts(self: *Agent) void {
+        var i: usize = 0;
+        while (i < self.history.items.len) {
+            if (isInternalToolHistoryMessage(self.history.items[i])) {
+                self.history.items[i].deinit(self.allocator);
+                _ = self.history.orderedRemove(i);
+                continue;
+            }
+            i += 1;
+        }
+    }
+
+    fn isInternalToolHistoryMessage(msg: OwnedMessage) bool {
+        const trimmed = std.mem.trim(u8, msg.content, " \t\r\n");
+
+        return switch (msg.role) {
+            .assistant => std.mem.indexOf(u8, trimmed, "<tool_call>") != null or
+                std.mem.indexOf(u8, trimmed, "[TOOL_CALL]") != null or
+                std.mem.indexOf(u8, trimmed, "[tool_call]") != null,
+            .user => std.mem.startsWith(u8, trimmed, "<tool_result"),
+            else => false,
+        };
+    }
