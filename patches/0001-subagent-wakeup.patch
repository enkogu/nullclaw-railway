+const SessionReplyRoute = struct {
+    channel: []const u8,
+    chat_id: []const u8,
+    account_id: ?[]const u8 = null,
+
+    fn deinit(self: *SessionReplyRoute, allocator: std.mem.Allocator) void {
+        allocator.free(self.channel);
+        allocator.free(self.chat_id);
+        if (self.account_id) |aid| allocator.free(aid);
+    }
+};
+
+fn upsertSessionReplyRoute(
+    allocator: std.mem.Allocator,
+    routes: *std.StringHashMapUnmanaged(SessionReplyRoute),
+    session_key: []const u8,
+    channel: []const u8,
+    chat_id: []const u8,
+    account_id: ?[]const u8,
+) !void {
+    const channel_copy = try allocator.dupe(u8, channel);
+    errdefer allocator.free(channel_copy);
+    const chat_copy = try allocator.dupe(u8, chat_id);
+    errdefer allocator.free(chat_copy);
+    const account_copy = if (account_id) |aid| try allocator.dupe(u8, aid) else null;
+    errdefer if (account_copy) |aid| allocator.free(aid);
+
+    if (routes.getEntry(session_key)) |entry| {
+        entry.value_ptr.deinit(allocator);
+        entry.value_ptr.* = .{
+            .channel = channel_copy,
+            .chat_id = chat_copy,
+            .account_id = account_copy,
+        };
+        return;
+    }
+
+    const key_copy = try allocator.dupe(u8, session_key);
+    errdefer allocator.free(key_copy);
+
+    try routes.put(allocator, key_copy, .{
+        .channel = channel_copy,
+        .chat_id = chat_copy,
+        .account_id = account_copy,
+    });
+}
+
+fn deinitSessionReplyRoutes(
+    allocator: std.mem.Allocator,
+    routes: *std.StringHashMapUnmanaged(SessionReplyRoute),
+) void {
+    var it = routes.iterator();
+    while (it.next()) |entry| {
+        allocator.free(entry.key_ptr.*);
+        entry.value_ptr.deinit(allocator);
+    }
+    routes.deinit(allocator);
+}
